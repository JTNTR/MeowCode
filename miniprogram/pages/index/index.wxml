<!--index.wxml-->
<view class="container">
  <!-- 猫猫头部装饰 -->
  <view class="hero-section">
    <view class="cat-ears">
      <text class="ear left-ear">🐱</text>
      <text class="ear right-ear">🐱</text>
    </view>
    <view class="hero-icon">🐾</view>
    <view class="hero-title">喵喵二维码</view>
    <view class="hero-subtitle">扫码识别 · 码上生成 · 一喵搞定</view>
    <view class="hero-badge">
      <text>✨ 条形码 · 二维码 ✨</text>
    </view>
  </view>

  <!-- 功能卡片 -->
  <view class="card-list">
    <!-- 条形码扫描 -->
    <view class="card card-pink" bindtap="onScanBarcode">
      <view class="card-left">
        <view class="card-icon-box icon-scan">
          <text class="card-emoji">📷</text>
        </view>
        <view class="card-info">
          <view class="card-title">条形码扫描</view>
          <view class="card-desc">扫描商品条形码，快速识别</view>
        </view>
      </view>
      <text class="card-arrow">🐾</text>
    </view>

    <!-- 二维码扫描 -->
    <view class="card card-blue" bindtap="onScanQRCode">
      <view class="card-left">
        <view class="card-icon-box icon-qrscan">
          <text class="card-emoji">📱</text>
        </view>
        <view class="card-info">
          <view class="card-title">二维码扫描</view>
          <view class="card-desc">扫描二维码，读取隐藏信息</view>
        </view>
      </view>
      <text class="card-arrow">🐾</text>
    </view>

    <!-- 条形码生成 -->
    <view class="card card-orange" bindtap="onGenBarcode">
      <view class="card-left">
        <view class="card-icon-box icon-genbar">
          <text class="card-emoji">📊</text>
        </view>
        <view class="card-info">
          <view class="card-title">条形码生成</view>
          <view class="card-desc">输入数字，一键生成条形码</view>
        </view>
      </view>
      <text class="card-arrow">🐾</text>
    </view>

    <!-- 二维码生成 -->
    <view class="card card-purple" bindtap="onGenQRCode">
      <view class="card-left">
        <view class="card-icon-box icon-genqr">
          <text class="card-emoji">🔳</text>
        </view>
        <view class="card-info">
          <view class="card-title">二维码生成</view>
          <view class="card-desc">输入文字/链接，生成二维码</view>
        </view>
      </view>
      <text class="card-arrow">🐾</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text>🐈 选择上方功能开始使用吧~</text>
  </view>
</view>
