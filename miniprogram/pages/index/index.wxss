/**index.wxss**/
page {
  background-color: #FFF5F0;
}

.container {
  padding: 0 30rpx 60rpx;
  min-height: 100vh;
}

/* ===== 头部区域 ===== */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
  position: relative;
}

.cat-ears {
  display: flex;
  gap: 120rpx;
  margin-bottom: -20rpx;
}

.ear {
  font-size: 60rpx;
  animation: earWiggle 2s ease-in-out infinite;
}

.left-ear { animation-delay: 0s; }
.right-ear { animation-delay: 0.3s; }

@keyframes earWiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
  animation: bounce 1.5s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FF6B8A, #FF8E6B);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #CC9A9A;
  margin-bottom: 20rpx;
}

.hero-badge {
  background: linear-gradient(135deg, #FFF0F3, #FFE8EC);
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
  border: 2rpx solid #FFD6E0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-badge text {
  font-size: 24rpx;
  color: #FF6B8A;
  font-weight: 500;
}

/* ===== 卡片网格 ===== */
.card-grid {
  width: 100%;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: flex-start;
}

.card-grid::after {
  content: '';
  width: 47%;
}

.card {
  width: 47%;
  background: #FFF;
  border-radius: 24rpx;
  padding: 32rpx 20rpx 24rpx;
  margin-bottom: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  transition: all 0.15s;
  border-top: 6rpx solid #FFD6E0;
  box-sizing: border-box;
}

.card:active {
  transform: scale(0.96);
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
}

.card-pink { border-top-color: #FF6B8A; }
.card-blue { border-top-color: #69C0FF; }
.card-orange { border-top-color: #FFA940; }
.card-purple { border-top-color: #D3ADF7; }
.card-teal { border-top-color: #5CDBD3; }

.card-icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.icon-scan { background: linear-gradient(135deg, #FFF0F3, #FFD6E0); }
.icon-qrscan { background: linear-gradient(135deg, #E6F7FF, #BAE7FF); }
.icon-genbar { background: linear-gradient(135deg, #FFF7E6, #FFE7BA); }
.icon-genqr { background: linear-gradient(135deg, #F9F0FF, #EFDBFF); }
.icon-horoscope { background: linear-gradient(135deg, #E6FFFA, #C1F0E8); }

.card-emoji {
  font-size: 48rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #AAA;
  text-align: center;
}

/* ===== 底部 ===== */
.footer-tip {
  width: 100%;
  text-align: center;
  padding: 40rpx 0;
}

.footer-tip text {
  font-size: 24rpx;
  color: #DDC0C0;
}
