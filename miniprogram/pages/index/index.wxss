/**index.wxss**/
page {
  background-color: #FFF5F0;
}

.container {
  padding: 0 30rpx 60rpx;
  min-height: 100vh;
}

/* ===== 头部区域 ===== */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
  position: relative;
}

.cat-ears {
  display: flex;
  gap: 120rpx;
  margin-bottom: -20rpx;
}

.ear {
  font-size: 60rpx;
  animation: earWiggle 2s ease-in-out infinite;
}

.left-ear { animation-delay: 0s; }
.right-ear { animation-delay: 0.3s; }

@keyframes earWiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
  animation: bounce 1.5s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FF6B8A, #FF8E6B);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #CC9A9A;
  margin-bottom: 20rpx;
}

.hero-badge {
  background: linear-gradient(135deg, #FFF0F3, #FFE8EC);
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
  border: 2rpx solid #FFD6E0;
}

.hero-badge text {
  font-size: 24rpx;
  color: #FF6B8A;
  font-weight: 500;
}

/* ===== 卡片列表 ===== */
.card-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #FFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  transition: all 0.15s;
  border-left: 8rpx solid #FFD6E0;
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
}

.card-pink { border-left-color: #FF6B8A; }
.card-blue { border-left-color: #69C0FF; }
.card-orange { border-left-color: #FFA940; }
.card-purple { border-left-color: #D3ADF7; }

.card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.card-icon-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-scan { background: linear-gradient(135deg, #FFF0F3, #FFD6E0); }
.icon-qrscan { background: linear-gradient(135deg, #E6F7FF, #BAE7FF); }
.icon-genbar { background: linear-gradient(135deg, #FFF7E6, #FFE7BA); }
.icon-genqr { background: linear-gradient(135deg, #F9F0FF, #EFDBFF); }

.card-emoji {
  font-size: 40rpx;
}

.card-info {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 23rpx;
  color: #AAA;
}

.card-arrow {
  font-size: 32rpx;
  color: #FFD6E0;
  flex-shrink: 0;
  animation: pawBounce 1.5s ease-in-out infinite;
}

@keyframes pawBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.3); }
}

/* ===== 底部 ===== */
.footer-tip {
  width: 100%;
  text-align: center;
  padding: 40rpx 0;
}

.footer-tip text {
  font-size: 24rpx;
  color: #DDC0C0;
}
